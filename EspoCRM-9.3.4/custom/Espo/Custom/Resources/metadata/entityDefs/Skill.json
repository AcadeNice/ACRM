{
    "entityClassName": "Espo\\Core\\Templates\\Entities\\Base",
    "repositoryClassName": "Espo\\Core\\Templates\\Repositories\\Base",
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "audited": true
        },
        "skillType": {
            "type": "enum",
            "options": ["technique", "logiciel", "softSkill", "metier", "langue", "autre"],
            "displayAsLabel": true,
            "audited": true
        },
        "skillCategory": {
            "type": "enum",
            "options": ["developpement", "noCode", "commerce", "graphisme", "bureautique", "marketing", "gestionProjet", "langues", "general"],
            "displayAsLabel": true,
            "audited": true
        },
        "description": {
            "type": "text",
            "audited": true
        },
        "active": {
            "type": "bool",
            "default": true,
            "audited": true
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "audited": true,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "audited": true,
            "view": "views/fields/teams"
        },
        "contacts": {
            "type": "linkMultiple"
        },
        "formations": {
            "type": "linkMultiple"
        },
        "opportunities": {
            "type": "linkMultiple"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "meetings": {
            "type": "hasMany",
            "entity": "Meeting",
            "foreign": "parent"
        },
        "calls": {
            "type": "hasMany",
            "entity": "Call",
            "foreign": "parent"
        },
        "tasks": {
            "type": "hasChildren",
            "entity": "Task",
            "foreign": "parent"
        },
        "emails": {
            "type": "hasChildren",
            "entity": "Email",
            "foreign": "parent",
            "layoutRelationshipsDisabled": true
        },
        "contacts": {
            "type": "hasMany",
            "entity": "Contact",
            "foreign": "skills",
            "relationName": "contactSkill"
        },
        "formations": {
            "type": "hasMany",
            "entity": "Formation",
            "foreign": "skills",
            "relationName": "formationSkill"
        },
        "opportunities": {
            "type": "hasMany",
            "entity": "Opportunity",
            "foreign": "skills",
            "relationName": "opportunitySkill"
        }
    },
    "indexes": {
        "assignedUser": {
            "columns": ["assignedUserId", "deleted"]
        },
        "createdAt": {
            "columns": ["createdAt"]
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "asc"
    }
}
