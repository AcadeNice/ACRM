    "links": {
        "formationPrincipale": {
            "type": "belongsTo",
            "entity": "Formation",
            "foreign": "contacts"
        },
        "responsableLegal": {
            "type": "belongsTo",
            "entity": "Contact",
            "foreign": "personnesRattachees"
        },
        "personnesRattachees": {
            "type": "hasMany",
            "entity": "Contact",
            "foreign": "responsableLegal"
        },
        "sourcePrescriberContact": {
            "type": "belongsTo",
            "entity": "Contact"
        },
        "sourcePrescriberAccount": {
            "type": "belongsTo",
            "entity": "Account"
        },
        "contactsAccompagnes": {
            "type": "hasMany",
            "entity": "Contact",
            "foreign": "tuteursEntreprise",
            "relationName": "contactTutorRelation"
        },
        "tuteursEntreprise": {
            "type": "hasMany",
            "entity": "Contact",
            "foreign": "contactsAccompagnes",
            "relationName": "contactTutorRelation"
        },
        "skills": {
            "type": "hasMany",
            "entity": "Skill",
            "foreign": "contacts",
            "relationName": "contactSkill"
        },
        "candidatures": {
            "type": "hasMany",
            "entity": "Candidature",
            "foreign": "contact"
        },
        "contrats": {
            "type": "hasMany",
            "entity": "Contrat",
            "foreign": "contact"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name",
            "emailAddress"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "optimisticConcurrencyControl": false
