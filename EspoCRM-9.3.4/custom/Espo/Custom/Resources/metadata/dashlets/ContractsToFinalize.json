{
    "view": "views/dashlets/abstract/record-list",
    "aclScope": "Contrat",
    "entityType": "Contrat",
    "options": {
        "view": "views/dashlets/options/record-list",
        "fields": {
            "title": {
                "type": "varchar",
                "required": true
            },
            "autorefreshInterval": {
                "type": "enumFloat",
                "options": [0, 0.5, 1, 2, 5, 10]
            },
            "displayRecords": {
                "type": "int",
                "min": 1,
                "max": 20
            },
            "expandedLayout": {
                "type": "base",
                "view": "views/dashlets/fields/records/expanded-layout"
            }
        },
        "defaults": {
            "title": "Contrats à finaliser",
            "displayRecords": 6,
            "autorefreshInterval": 0.5,
            "sortBy": "dateDebut",
            "sortDirection": "desc",
            "searchData": {
                "advanced": [
                    {
                        "attribute": "statutContrat",
                        "type": "notIn",
                        "value": ["signe", "annule", "rompu"]
                    }
                ]
            },
            "expandedLayout": {
                "rows": [
                    [
                        {
                            "name": "name",
                            "link": true
                        }
                    ],
                    [
                        {
                            "name": "statutContrat"
                        },
                        {
                            "name": "filizStatus"
                        }
                    ]
                ]
            }
        }
    }
}
